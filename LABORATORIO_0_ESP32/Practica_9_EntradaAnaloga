#include<Arduino.h>

// Potenciometro esta connectado al GPIO 34 (Analog ADC1_CH6) 
const int potPin = 34;

// variable para almacenar el valor del potenciometro
int potValue = 0;

void setup() {
  Serial.begin(9600);
  //delay(1000);
}

void loop() {
  // Leyendo el valor del potenciometro
  potValue = analogRead(potPin);
  Serial.println(potValue);
  delay(50);
}
