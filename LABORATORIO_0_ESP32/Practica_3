#include <Arduino.h>
#define LED 5
float per=0.5;

void setup() {
  Serial.begin(9600);
   pinMode(LED, OUTPUT);
}

void loop() {
  digitalWrite(LED, HIGH);
  Serial.println("Led esta ON");
  delay(per*1000);
  digitalWrite(LED, LOW);
  Serial.println("Led esta OFF");
  Serial.print("A una frecuencia de = ");
  Serial.print(1/(2.0*per));
  Serial.println("Hz");
  delay(per*1000);
}
