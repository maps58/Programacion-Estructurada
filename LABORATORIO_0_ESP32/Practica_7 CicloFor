#include <Arduino.h>

#define sw1 12
int leds[] = {0,1,2,3,4,5,6,7};

void setup() {
 pinMode(sw1,INPUT);
   for(int i = 0; i <= 7; i++) {
    pinMode(i, OUTPUT); 
}
}
void loop() {  
  if (digitalRead(sw1)) {
     for(int i = 0; i<=7; i++){
    digitalWrite(i, HIGH);
    delay(500);
    digitalWrite(leds[i], LOW);
     } }
     
  else {
     for(int i = 7; i>=0  ; i--){
    digitalWrite(i, HIGH);
    delay(500);
    digitalWrite(leds[i], LOW);
     } }}
 
