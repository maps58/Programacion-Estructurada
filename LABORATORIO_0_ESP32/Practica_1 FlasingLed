/* Práctica No. 1 (Aprender a configurar los GPIOs).
Los ESP32’s traen por default un “led” conectado en la patilla 2 (built-in led)*/

#include <Arduino.h>
#define LED 2

void setup() {
  // Colocar aca el código de configuracion; se ejecuta solo una vez:
  Serial.begin(9600)
   pinMode(LED, OUTPUT);
}

void loop() {
  // poner su código principal aca, se ejecutará en modo bucle:
  digitalWrite(LED, HIGH);
  delay(500);
  digitalWrite(LED, LOW);
  delay(500);
}
