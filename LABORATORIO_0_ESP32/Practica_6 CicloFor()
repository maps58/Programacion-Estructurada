
  #include <Arduino.h>
  #define LED_1 2
  #define LED_2 5

  void setup() {

  pinMode(LED_1, OUTPUT);
  pinMode(LED_2, OUTPUT);
  }

  void loop() {

for (int i = 1; i <= 10; i++) {
  digitalWrite(LED_1, HIGH);
  delay(500);
  digitalWrite(LED_1, LOW);
  delay(500);
}

for (int j = 1; j <= 5; j++) {
  digitalWrite(LED_2, HIGH);
  delay(500);
  digitalWrite(LED_2, LOW);
  delay(500);
}
  }
  
