#include <Arduino.h>
#define LED  2
#define sw1 12
#define sw2 13

void setup() {
 pinMode(LED, OUTPUT);
 pinMode(sw1, INPUT);
 pinMode(sw2, INPUT);
}

void loop() {
  //Enciende LED solo cuando sw1 y sw2 estan cerrados
  if (digitalRead(sw1) && digitalRead (sw2)) 
    digitalWrite(LED,HIGH);  
   else 
    digitalWrite(LED,LOW);  
}
  
